# JARVIS Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# GITHUB COPILOT CLI
# =============================================================================
COPILOT_CLI_ENABLED=true
COPILOT_MODEL_FAST=gpt-4.1-mini
COPILOT_MODEL_SMART=gpt-4.1
COPILOT_TIMEOUT=60

# =============================================================================
# TTS (Windows-friendly Kokoro local or Edge neural)
# =============================================================================
TTS_ENGINE=edge
TTS_VOICE=en-GB-RyanNeural
# Optional Kokoro local settings (only needed when TTS_ENGINE=kokoro)
# TTS_KOKORO_VOICE=af_bella
# TTS_KOKORO_LANG=b
# TTS_KOKORO_DEVICE=cpu
# TTS_KOKORO_SPEED=1.0

# =============================================================================
# TERMINAL / POWERSHELL (Windows)
# =============================================================================
POWERSHELL_ENABLED=true
POWERSHELL_EXECUTION_POLICY=RemoteSigned
TERMINAL_TIMEOUT=30
# Optional: where to log executed commands
# TERMINAL_LOG_PATH=C:\Users\you\.jarvis_terminal.log

# =============================================================================
# GENERAL SETTINGS
# =============================================================================
USER_NAME=Tony
# CALENDAR_ACCOUNTS=you@gmail.com,work@company.com
