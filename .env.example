# JARVIS Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# GITHUB COPILOT CLI
# =============================================================================
COPILOT_CLI_ENABLED=true
COPILOT_MODEL_FAST=gpt-4.1-mini
COPILOT_MODEL_SMART=gpt-4.1
COPILOT_TIMEOUT=60

# =============================================================================
# TTS (Piper local neural TTS + pyttsx3 Windows SAPI5 fallback)
# =============================================================================
# Choose TTS engine: "piper" (default, neural-quality) or "pyttsx3" (Windows SAPI5)
TTS_ENGINE=piper

# Piper TTS Settings (primary engine - lightweight, CPU-friendly, neural quality)
# Voice options: en_US-ryan-high, en_GB-alan-medium, en_US-amy-medium, etc.
# Download voices from: https://github.com/rhasspy/piper/releases
PIPER_VOICE=en_US-ryan-high
# Optional: Full path to .onnx model file (auto-detects in ./voices/ if not set)
# PIPER_MODEL_PATH=./voices/en_US-ryan-high.onnx
# PIPER_SAMPLE_RATE=22050

# pyttsx3 Settings (fallback engine - uses Windows native voices)
# Leave empty for default Windows voice, or specify a voice name
# PYTTSX3_VOICE=
# PYTTSX3_RATE=180

# Legacy TTS_VOICE (used as fallback for Piper voice selection)
TTS_VOICE=en_US-ryan-high

# =============================================================================
# TERMINAL / POWERSHELL (Windows)
# =============================================================================
POWERSHELL_ENABLED=true
POWERSHELL_EXECUTION_POLICY=RemoteSigned
TERMINAL_TIMEOUT=30
# Optional: where to log executed commands
# TERMINAL_LOG_PATH=C:\Users\you\.jarvis_terminal.log

# =============================================================================
# GENERAL SETTINGS
# =============================================================================
USER_NAME=Tony
# CALENDAR_ACCOUNTS=you@gmail.com,work@company.com
