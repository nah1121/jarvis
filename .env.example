# JARVIS Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# ANTHROPIC API CONFIGURATION (for macOS / cloud API)
# =============================================================================
# If running on macOS with the real Anthropic API, set this:
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# LOCAL LLM PROXY (for Windows / free-claude-code)
# =============================================================================
# If using free-claude-code proxy with local LLM (LM Studio, NVIDIA NIM, etc.)
# Set these instead of ANTHROPIC_API_KEY:
ANTHROPIC_BASE_URL=http://localhost:8082
ANTHROPIC_API_KEY=freecc

# =============================================================================
# FISH AUDIO CLOUD TTS (for macOS)
# =============================================================================
# If running on macOS with Fish Audio cloud API:
# FISH_API_KEY=your-fish-audio-api-key-here
# FISH_VOICE_ID=612b878b113047d9a770c069c8b4fdfe

# =============================================================================
# LOCAL TTS (for Windows / Fish Speech server)
# =============================================================================
# If using local Fish Speech server (Windows):
TTS_BASE_URL=http://localhost:8080
TTS_VOICE_ID=male_en
# Optional: Path to reference audio file for voice cloning
# TTS_REFERENCE_AUDIO=C:\fish-speech\references\jarvis.wav

# =============================================================================
# TERMINAL / POWERSHELL (Windows)
# =============================================================================
# Enable or disable PowerShell automation (Windows only)
POWERSHELL_ENABLED=true
# Recommended execution policy for voice-triggered scripts (set globally to RemoteSigned)
POWERSHELL_EXECUTION_POLICY=RemoteSigned
# Timeout (seconds) for terminal commands
TERMINAL_TIMEOUT=30
# Optional: where to log executed commands
# TERMINAL_LOG_PATH=C:\Users\you\.jarvis_terminal.log

# =============================================================================
# GENERAL SETTINGS
# =============================================================================
# Optional: Your name (JARVIS will address you by name)
USER_NAME=Tony

# Optional: Specific Apple Calendar accounts to read (comma-separated emails)
# macOS only - ignored on Windows
# If not set, JARVIS reads ALL calendars from Apple Calendar
# CALENDAR_ACCOUNTS=you@gmail.com,work@company.com
